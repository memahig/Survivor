{
  "max_chars": 2400,
  "confidence_weights": { "low": 1, "medium": 2, "high": 3 },
  "model_weights": { "openai": 1.0, "gemini": 1.0, "claude": 1.0, "mock_openai": 1.0, "mock_gemini": 1.0, "mock_claude": 1.0 },
  "decision_margin": 2,
  "max_claims_per_reviewer": 30,
  "max_pillar_claims_per_reviewer": 8,
  "max_questionable_claims_per_reviewer": 12,
  "max_omission_candidates": 4,
  "max_counterfactuals": 3,
  "max_rival_narratives": 3,
  "centrality_backstop_k": 5,
  "background_sample_n": 0,
  "max_near_duplicate_links": 3,
  "near_duplicate_similarity_threshold": 0.92,
  "reviewers_enabled": ["openai", "gemini", "claude"],
  "adversarial_cross_review": true,
  "cross_review_mode": "structured_only",
  "verification_enabled": true,
  "verification_max_claims": 20,
  "verification_kinds_enabled": ["world_fact", "document_content"],
  "gsae_settings": {
    "enabled": true,
    "epsilon": 0.1,
    "tau": 0.25,
    "weights": {
      "classification_bucket": 0.10,
      "intent_level": 0.10,
      "requires_corrob": 0.10,
      "omission_load_bearing": 0.10,
      "severity_toward_subject": 0.25,
      "severity_toward_counterparty": 0.25,
      "confidence_band": 0.10
    },
    "version": "0.3"
  },
  "outputs": {
    "main_report": "report.md",
    "run_json": "run.json",
    "tickets_json": "tickets.json",
    "debug_md": "debug.md"
  }
}